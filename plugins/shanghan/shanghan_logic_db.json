      "source_clause": [
        {
          "clause_number": "12",
          "text": "太陽中風，陽浮而陰弱，陽浮者，熱自發；陰弱者，汗自出。嗇嗇惡寒，淅淅惡風，翕翕發熱，鼻鳴乾嘔者，桂枝湯主之。"
        },
        {
          "clause_number": "13",
          "text": "太陽病，頭痛、發熱、汗出、惡風，桂枝湯主之。"
        }
      ]
    },
